{
  "name": "seed4t",
  "version": "0.1.0",
  "description": "TDD scaffolding generator (bricks -> resolved recipe) with an emergent hexagonal architecture",
  "license": "MIT",
  "author": "remyShift",
  "private": true,
  "packageManager": "pnpm@10.18.2",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "test:run": "pnpm -r run test:run",
    "coverage": "pnpm -r run coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0"
  }
}
